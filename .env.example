# ============================================================
# UPSTASH REDIS - Serverless Cach e
# Lấy tại: https://console.upstash.com
# ============================================================
UPSTASH_REDIS_REST_URL="https://your-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# ============================================================
# SUPABASE - Postgres Database
# Lay tai: https://supabase.com
# ============================================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Store the same value in Supabase Vault as `ketquawc_cron_secret`
CRON_SECRET="your-cron-secret"
FOOTBALL_SYNC_LEAGUE_IDS="1,2,3,848,39,140,78,135,61,94,88,203,144,253,262,71,128,13,340,341"
FOOTBALL_SYNC_PAST_DAYS="3"
FOOTBALL_SYNC_FUTURE_DAYS="10"

# ============================================================
# API-FOOTBALL - External Sports Data Source
# Lấy tại: https://www.api-football.com
# ============================================================
API_FOOTBALL_KEY="your-api-key-here"
API_FOOTBALL_BASE_URL="https://v3.football.api-sports.io"
API_FOOTBALL_MAX_RPM="280"

# ============================================================
# SITE CONFIG
# ============================================================
NEXT_PUBLIC_SITE_URL="https://ketquawc.vn"
NEXT_PUBLIC_SITE_NAME="KetquaWC.vn"
GOOGLE_AI_MODEL="gemini-2.5-flash"

# Google AdSense Publisher ID (điền sau khi được duyệt)
NEXT_PUBLIC_ADSENSE_PID="ca-pub-XXXXXXXXXXXXXXXXX"
